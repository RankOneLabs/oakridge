# lbc-dashboard reads these from the backend process environment.
# For local development, put real values in lbc-dashboard/.env.

# Provider keys inherited by legit-biz-club runs launched from the dashboard.
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Dashboard server config.
LBC_DASHBOARD_PORT=8765
LBC_DASHBOARD_HOST=127.0.0.1

# Local storage paths. Defaults work for the standard oakridge layout.
LBC_RUN_ROOT=../legit-biz-club/.run
LBC_DASHBOARD_DATA_ROOT=./data
