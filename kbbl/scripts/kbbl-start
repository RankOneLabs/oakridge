#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "usage: kbbl-start <workdir> [--port=<port>] [--host=<addr>]" >&2
  echo "  --host defaults to 127.0.0.1; pass 0.0.0.0 for tailnet/phone access" >&2
  exit 1
fi

WORKDIR="$1"
shift

if [ ! -d "$WORKDIR" ]; then
  echo "kbbl-start: workdir not found: $WORKDIR" >&2
  exit 1
fi

WORKDIR_ABS="$(cd "$WORKDIR" && pwd)"
KBBL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Rebuild the PWA bundle so a fresh `git pull` doesn't silently serve a
# stale pwa/dist. Vite is fast (~1s) and the dist is required to serve
# anything useful, so eat the cost unconditionally.
(cd "$KBBL_ROOT" && bun run build:pwa)

exec bun run "$KBBL_ROOT/core/server.ts" --workdir="$WORKDIR_ABS" "$@"
