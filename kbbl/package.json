{
  "name": "kbbl",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Operator surface for CLI coding agents. Tablet-first PWA over Tailscale.",
  "scripts": {
    "dev": "bun run --hot core/server.ts",
    "prestart": "bun run build:pwa",
    "start": "bun run core/server.ts",
    "build:pwa": "cd core/pwa && vite build",
    "dev:pwa": "cd core/pwa && vite",
    "test": "bun test core/config.test.ts core/db core/github core/orchestrator core/review core/server core/session adapters/claude-code adapters/codex core/runtime.conformance.test.ts",
    "test:pwa": "cd core/pwa && vitest run",
    "test:all": "bun run test && bun run test:pwa"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.13",
    "@types/dagre": "^0.7.54",
    "dagre": "^0.8.5",
    "hono": "^4.6.14",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "reactflow": "11",
    "rehype-sanitize": "^6.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
