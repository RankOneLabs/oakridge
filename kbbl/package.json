{
  "name": "kbbl",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Operator surface for CLI coding agents. Tablet-first PWA over Tailscale.",
  "scripts": {
    "dev": "bun run --hot core/server.ts",
    "prestart": "bun run build:pwa",
    "start": "bun run core/server.ts",
