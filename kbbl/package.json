    "dev:pwa": "cd core/pwa && vite",
    "test": "bun test"
  },
  "dependencies": {
    "@types/dagre": "^0.7.54",
    "dagre": "^0.8.5",
    "hono": "^4.6.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "reactflow": "11",
    "rehype-sanitize": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
